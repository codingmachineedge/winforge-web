{
  "name": "winforge-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web (React + TypeScript / Vite) rewrite of WinForge — module catalog browser + PWR reactor simulator, bilingual EN / 繁體中文.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "gen:catalog": "node tools/gen-catalog.mjs",
    "gen:registry-keys": "node tools/gen-registry-keys.mjs",
    "gen:i18n-shell": "node tools/gen-i18n-shell.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/oxanium": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.9",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "i18next": "^23.16.8",
    "material-symbols": "^0.45.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
